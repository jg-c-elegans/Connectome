{
  "private": true,
  "name": "connectome-product-ext",
  "version": "1.2.2",
  "description": "Connectome product identity, theme, layout, and desktop integration",
  "author": "James Grimm <contact@jgrimm.dev>",
  "dependencies": {
    "@theia/ai-registry": "1.73.1",
    "@theia/core": "1.73.1",
    "@theia/editor": "1.73.1",
    "@theia/getting-started": "1.73.1",
    "@theia/monaco": "1.73.1",
    "@theia/terminal": "1.73.1",
    "@theia/vsx-registry": "1.73.1",
    "@theia/workspace": "1.73.1",
    "inversify": "^6.2.2"
  },
  "devDependencies": {
    "rimraf": "^2.7.1",
    "tslint": "^5.20.1",
    "typescript": "^4.9.5"
  },
  "theiaExtensions": [
    {
      "frontend": "lib/browser/connectome-frontend-module",
      "backend": "lib/node/connectome-backend-module"
    },
    {
      "preload": "lib/electron-browser/system-preload",
      "electronMain": "lib/electron-main/system-electron-main-module"
    }
  ],
  "keywords": [
    "connectome-extension"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jg-c-elegans/connectome.git"
  },
  "bugs": {
    "url": "https://github.com/jg-c-elegans/connectome/issues"
  },
  "homepage": "https://github.com/jg-c-elegans/connectome#readme",
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
    "clean": "rimraf lib *.tsbuildinfo",
    "build": "tsc -b",
    "lint": "eslint --ext js,jsx,ts,tsx src",
    "lint:fix": "eslint --ext js,jsx,ts,tsx src --fix",
    "update:theia": "ts-node ../../scripts/update-theia-version.ts",
    "update:next": "ts-node ../../scripts/update-theia-version.ts next"
  },
  "peerDependencies": {
    "react": "^18.3.1"
  }
}
