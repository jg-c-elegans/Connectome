{
  "$schema": "vscode://schemas/color-theme",
  "name": "Connectome (Dark)",
  "colors": {
    "foreground": "#F2F3F5",
    "descriptionForeground": "#F2F3F5B3",
    "errorForeground": "#F84A5A",
    "focusBorder": "#5A36FA",
    "selection.background": "#5A36FA66",
    "widget.border": "#3B3F89",
    "widget.shadow": "#000000B3",
    "icon.foreground": "#F2F3F5",

    "editor.background": "#050916",
    "editor.foreground": "#F2F3F5",
    "editorLineNumber.foreground": "#3B3F89",
    "editorLineNumber.activeForeground": "#A667F4",
    "editorCursor.foreground": "#5A36FA",
    "editor.selectionBackground": "#5A36FA66",
    "editor.inactiveSelectionBackground": "#5A36FA33",
    "editor.selectionHighlightBackground": "#01C6FD33",
    "editor.wordHighlightBackground": "#3B3F8966",
    "editor.wordHighlightStrongBackground": "#3B3F8999",
