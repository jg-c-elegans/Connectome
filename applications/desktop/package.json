{
  "private": true,
  "name": "connectome-desktop-app",
  "description": "Connectome Windows desktop application",
  "productName": "Connectome",
  "version": "1.2.2",
  "main": "scripts/connectome-desktop-main.js",
  "license": "MIT",
  "author": "James Grimm <contact@jgrimm.dev>",
  "homepage": "https://github.com/jg-c-elegans/connectome#readme",
  "bugs": {
    "url": "https://github.com/jg-c-elegans/connectome/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jg-c-elegans/connectome.git"
  },
  "engines": {
    "yarn": ">=1.7.0 <2",
    "node": ">=22"
  },
  "theia": {
    "target": "electron",
    "frontend": {
      "config": {
        "applicationName": "Connectome",
        "reloadOnReconnect": true,
        "defaultTheme": "connectome-dark",
        "electron": {
          "showWindowEarly": false,
          "windowOptions": {
            "icon": "resources/icons/WindowIcon/512-512.png",
            "webPreferences": {
              "webviewTag": true
            }
          },
          "splashScreenOptions": {
            "content": "resources/ConnectomeSplash.svg",
            "height": 276,
            "width": 446
          }
        }
      }
    },
    "backend": {
      "config": {
        "frontendConnectionTimeout": -1,
        "startupTimeout": -1,
        "resolveSystemPlugins": false,
        "configurationFolder": ".connectome"
      }
    },
    "generator": {
      "config": {
        "preloadTemplate": "./resources/preload.html"
      }
    }
  },
  "dependencies": {
    "@theia/ai-anthropic": "1.73.1",
    "@theia/ai-chat": "1.73.1",
    "@theia/ai-chat-ui": "1.73.1",
    "@theia/ai-claude-code": "1.73.1",
    "@theia/ai-code-completion": "1.73.1",
    "@theia/ai-codex": "1.73.1",
    "@theia/ai-copilot": "1.73.1",
    "@theia/ai-core": "1.73.1",
    "@theia/ai-core-ui": "1.73.1",
    "@theia/ai-editor": "1.73.1",
    "@theia/ai-google": "1.73.1",
    "@theia/ai-history": "1.73.1",
    "@theia/ai-huggingface": "1.73.1",
    "@theia/ai-ide": "1.73.1",
    "@theia/ai-llamafile": "1.73.1",
    "@theia/ai-mcp": "1.73.1",
    "@theia/ai-mcp-server": "1.73.1",
    "@theia/ai-mcp-ui": "1.73.1",
    "@theia/ai-ollama": "1.73.1",
    "@theia/ai-openai": "1.73.1",
    "@theia/ai-registry": "1.73.1",
    "@theia/ai-scanoss": "1.73.1",
    "@theia/ai-terminal": "1.73.1",
    "@theia/ai-vercel-ai": "1.73.1",
    "@theia/bulk-edit": "1.73.1",
    "@theia/callhierarchy": "1.73.1",
    "@theia/collaboration": "1.73.1",
    "@theia/console": "1.73.1",
    "@theia/core": "1.73.1",
    "@theia/debug": "1.73.1",
    "@theia/dev-container": "1.73.1",
    "@theia/editor": "1.73.1",
    "@theia/editor-preview": "1.73.1",
    "@theia/electron": "1.73.1",
    "@theia/external-terminal": "1.73.1",
    "@theia/file-search": "1.73.1",
    "@theia/filesystem": "1.73.1",
    "@theia/getting-started": "1.73.1",
